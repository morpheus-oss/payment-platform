root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.java]
indent_style = space
indent_size = 4

[*.xml]
indent_style = space
indent_size = 2

[*.yml]
indent_style = space
indent_size = 2

[*.yaml]
indent_style = space
indent_size = 2

[*.properties]
indent_style = space
indent_size = 2

[*.sql]
indent_style = space
indent_size = 4

[*.sh]
end_of_line = lf

[*.bat]
end_of_line = crlf
